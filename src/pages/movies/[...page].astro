---
import Base from '../../layouts/Base.astro';
import CategoryListing from '../../components/CategoryListing.astro';
import { getTitlesByCategory, toIndexEntry } from '../../lib/titles';
import { PAGE_SIZE, PRIMARY_GENRES, buildYearBuckets, buildGenreCounts } from '../../lib/filters';

export async function getStaticPaths() {
  const items = getTitlesByCategory('movie').map(toIndexEntry);
  const totalPages = Math.max(1, Math.ceil(items.length / PAGE_SIZE));
  const paths: any[] = [{ params: { page: undefined }, props: { current: 1 } }];
  for (let p = 1; p <= totalPages; p++) paths.push({ params: { page: `page/${p}` }, props: { current: p } });
  return paths;
}

const { current } = Astro.props as { current: number };
const all = getTitlesByCategory('movie');
const items = all.map(toIndexEntry);
const yearBuckets = buildYearBuckets(all);
const genreCounts = buildGenreCounts(all);
const visibleGenres = PRIMARY_GENRES.filter((g) => (genreCounts.get(g) || 0) > 0);
const totalPages = Math.max(1, Math.ceil(items.length / PAGE_SIZE));
const start = (current - 1) * PAGE_SIZE;
const slice = items.slice(start, start + PAGE_SIZE);
function pageHref(p: number): string { return p === 1 ? '/movies' : `/movies/page/${p}`; }
---

<Base title={current > 1 ? `أفلام مترجمة اون لاين مجاناً — صفحة ${current}` : 'أفلام مترجمة اون لاين مجاناً'} description={`تصفح مكتبة سينما برو التي تضم ${items.length} فيلمًا مترجمًا بجودة عالية.`}>
  <CategoryListing
    label="مكتبة الأفلام"
    icon="🎬"
    eyebrow="MOVIES COLLECTION"
    description={`واجهة جديدة تماماً لاستكشاف ${items.length.toLocaleString('ar-EG')} فيلم، مع فلاتر Pills أفقية وشبكة بطاقات حديثة.`}
    basePath="/movies"
    items={items}
    slice={slice}
    current={current}
    totalPages={totalPages}
    pageHref={pageHref}
    visibleGenres={visibleGenres}
    genreCounts={genreCounts}
    yearBuckets={yearBuckets}
  />
</Base>
