---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TitleDetailContent from '../../components/TitleDetailContent.astro';
import { getTitleBySlug, getTitlesByCategory, getSimilarTitles, toIndexEntry } from '../../lib/titles';
import { SITE } from '../../lib/site';
import {
  buildJsonLdDescription,
  buildMetaDescription,
  buildSeoTitle,
  cleanBrand,
  getDisplayTitle,
  getRating,
  splitGenres,
} from '../../lib/detailContent';

const moviePatternOverrides: Record<string, number> = {
  '1-million-followers-2024-مترجم-اون-لاين': 0,
  '12-desperate-hours-2023-مترجم-اون-لاين': 1,
  '12-to-midnight-2024-مترجم-اون-لاين': 2,
  '13th-summer-2024-مترجم-اون-لاين': 3,
  '15-cameras-2023-مترجم-اون-لاين': 4,
  '20-days-in-mariupol-2023-مترجم-اون-لاين': 5,
  '2073-2024-مترجم-اون-لاين': 6,
  '3-days-in-malay-2023-مترجم-اون-لاين': 7,
  '57-seconds-2023-مترجم-اون-لاين': 8,
  '5lbs-of-pressure-2024-مترجم-اون-لاين': 9,
};

export async function getStaticPaths() {
  const moviePatternOverrides: Record<string, number> = {
    '1-million-followers-2024-مترجم-اون-لاين': 0,
    '12-desperate-hours-2023-مترجم-اون-لاين': 1,
    '12-to-midnight-2024-مترجم-اون-لاين': 2,
    '13th-summer-2024-مترجم-اون-لاين': 3,
    '15-cameras-2023-مترجم-اون-لاين': 4,
    '20-days-in-mariupol-2023-مترجم-اون-لاين': 5,
    '2073-2024-مترجم-اون-لاين': 6,
    '3-days-in-malay-2023-مترجم-اون-لاين': 7,
    '57-seconds-2023-مترجم-اون-لاين': 8,
    '5lbs-of-pressure-2024-مترجم-اون-لاين': 9,
  };
  const movies = getTitlesByCategory('movie');
  return movies.map((t, index) => ({
    params: { slug: t.slug },
    props: { patternId: moviePatternOverrides[t.slug] ?? Math.floor(index / 10) % 10 },
  }));
}

const { patternId } = Astro.props as { patternId: number };
const routeSlug = Astro.params.slug as string;
const title = getTitleBySlug(routeSlug);
if (!title) {
  throw new Error(`Movie not found for slug: ${routeSlug}`);
}
const detailKind = 'movie' as const;
const primaryEpisode = title.seasons[0]?.episodes[0] ?? null;
const similar = getSimilarTitles(title, 12).map(toIndexEntry);
const genres = splitGenres(title.genre);
const displayTitle = getDisplayTitle(title);
const pageTitle = buildSeoTitle(title, detailKind);
const pageDescription = buildMetaDescription(title, detailKind);
const jsonLdDescription = buildJsonLdDescription(title, detailKind);
const rating = getRating(title);
const videoUploadDate = title.year ? `${title.year}-01-01` : '2024-01-01';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Movie',
  name: displayTitle,
  description: jsonLdDescription,
  image: title.poster || undefined,
  inLanguage: cleanBrand(title.language) || 'ar',
  url: new URL(title.url, SITE.url).toString(),
  ...(title.year ? { datePublished: title.year } : {}),
  ...(title.director ? { director: { '@type': 'Person', name: cleanBrand(title.director) } } : {}),
  ...(title.duration ? { duration: cleanBrand(title.duration) } : {}),
  ...(genres.length ? { genre: genres } : {}),
  ...(title.stars ? { actor: title.stars.split(/[\/،,]/).map((s: string) => ({ '@type': 'Person', name: cleanBrand(s) })).filter((actor) => actor.name) } : {}),
  ...(title.trailerId ? {
    trailer: {
      '@type': 'VideoObject',
      name: `تريلر ${displayTitle}`,
      description: `تريلر ${displayTitle} على سينما برو`,
      thumbnailUrl: `https://img.youtube.com/vi/${title.trailerId}/hqdefault.jpg`,
      uploadDate: videoUploadDate,
      embedUrl: `https://www.youtube.com/embed/${title.trailerId}`,
    },
  } : {}),
};
---

<Base title={pageTitle} description={pageDescription} image={title.poster ?? undefined} ogType="video.movie" jsonLd={jsonLd}>
  <TitleDetailContent title={title} kind={detailKind} similar={similar} similarHref="/movies" patternId={patternId} />
</Base>
