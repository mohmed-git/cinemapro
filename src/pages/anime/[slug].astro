---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TitleDetailContent from '../../components/TitleDetailContent.astro';
import { getTitlesByCategory, getSimilarTitles, toIndexEntry } from '../../lib/titles';
import { SITE } from '../../lib/site';
import { getFirstEpisodeRoute, getRouteSlug } from '../../lib/episodeRoutes';
import {
  buildJsonLdDescription,
  buildMetaDescription,
  buildSeoTitle,
  cleanBrand,
  getDisplayTitle,
  getRating,
  splitGenres,
} from '../../lib/detailContent';

const animePatternOverrides: Record<string, number> = {
  'ao-no-exorcist': 0,
  'blue-lock': 1,
  'boku-no-hero-academia': 2,
  'bungou-stray-dogs': 3,
  'diamond-no-ace-act-ii': 4,
  'dr-stone': 5,
  'golden-kamuy': 6,
  'jujutsu-kaisen': 7,
  'one-punch-man': 8,
  'oshi-no-ko': 9,
  'record-of-ragnarok': 5,
};

export async function getStaticPaths() {
  const animePatternOverrides: Record<string, number> = {
    'ao-no-exorcist': 0,
    'blue-lock': 1,
    'boku-no-hero-academia': 2,
    'bungou-stray-dogs': 3,
    'diamond-no-ace-act-ii': 4,
    'dr-stone': 5,
    'golden-kamuy': 6,
    'jujutsu-kaisen': 7,
    'one-punch-man': 8,
    'oshi-no-ko': 9,
    'record-of-ragnarok': 5,
  };
  const anime = getTitlesByCategory('anime');
  return anime.map((t, index) => ({
    params: { slug: getRouteSlug(t, 'anime') },
    props: { patternId: animePatternOverrides[t.slug] ?? Math.floor(index / 10) % 10 },
  }));
}

const { patternId } = Astro.props as { patternId: number };
const routeSlug = Astro.params.slug as string;
const title = getTitlesByCategory('anime').find((item) => getRouteSlug(item, 'anime') === routeSlug);
if (!title) {
  throw new Error(`Anime not found for route slug: ${routeSlug}`);
}
const detailKind = 'anime' as const;
const firstEp = title.seasons[0]?.episodes[0] ?? null;
const firstEpisodeHref = getFirstEpisodeRoute(title, detailKind);
const similar = getSimilarTitles(title, 12).map(toIndexEntry);
const genres = ['أنمي', ...splitGenres(title.genre).filter((genre) => genre !== 'أنمي')];
const displayTitle = getDisplayTitle(title);
const pageTitle = buildSeoTitle(title, detailKind);
const pageDescription = buildMetaDescription(title, detailKind);
const jsonLdDescription = buildJsonLdDescription(title, detailKind);
const rating = getRating(title);
const videoUploadDate = title.year ? `${title.year}-01-01` : '2024-01-01';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TVSeries',
  name: displayTitle,
  description: jsonLdDescription,
  image: title.poster || undefined,
  inLanguage: cleanBrand(title.language) || 'ar',
  numberOfSeasons: title.seasons_count,
  numberOfEpisodes: title.episodes_count,
  url: new URL(title.url, SITE.url).toString(),
  ...(title.year ? { datePublished: title.year } : {}),
  genre: genres,
  ...(title.stars ? { actor: title.stars.split(/[\/،,]/).map((s: string) => ({ '@type': 'Person', name: cleanBrand(s) })).filter((actor) => actor.name) } : {}),
  ...(title.trailerId ? {
    trailer: {
      '@type': 'VideoObject',
      name: `تريلر ${displayTitle}`,
      description: `تريلر ${displayTitle} على سينما برو`,
      thumbnailUrl: `https://img.youtube.com/vi/${title.trailerId}/hqdefault.jpg`,
      uploadDate: videoUploadDate,
      embedUrl: `https://www.youtube.com/embed/${title.trailerId}`,
    },
  } : {}),
};
---

<Base title={pageTitle} description={pageDescription} image={title.poster ?? undefined} ogType="video.tv_show" jsonLd={jsonLd}>
  <TitleDetailContent title={title} kind={detailKind} similar={similar} similarHref="/anime" patternId={patternId} />
</Base>
