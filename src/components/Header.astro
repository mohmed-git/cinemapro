---
import { SITE, NAV } from '../lib/site';
const { currentPath = '' } = Astro.props as { currentPath?: string };
const path = currentPath || Astro.url.pathname;

// Navigation icons (SVG paths for a richer mobile bottom-bar)
const navIcons: Record<string, string> = {
  '/': 'M3 12l2-2m0 0l7-7 7 7m-9 2v8m-4-8h12',
  '/movies': 'M15.6 11.6L22 7v10l-6.4-4.5v-1zM2 5a2 2 0 012-2h12a2 2 0 012 2v14a2 2 0 01-2 2H4a2 2 0 01-2-2V5z',
  '/series': 'M2 7h20v13H2zM7 4l5 3 5-3',
  '/anime': 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  '/search': 'M21 21l-4.3-4.3M11 19a8 8 0 110-16 8 8 0 010 16z',
};
---

<header id="site-header" class="fixed top-0 right-0 left-0 z-50 transition-all duration-300">
  <!-- Glassmorphism background -->
  <div class="header-bg absolute inset-0 transition-all duration-500"></div>

  <div class="container-app relative flex h-16 lg:h-[72px] items-center justify-between gap-4">
    <!-- Logo with glowing accent -->
    <a href="/" class="group relative flex items-center gap-2.5 font-display font-extrabold text-white shrink-0">
      <!-- Logo mark: Play icon inside gradient circle with neon halo -->
      <span class="relative flex h-10 w-10 lg:h-11 lg:w-11 items-center justify-center rounded-xl bg-gradient-to-br from-brand-600 via-neon-violet to-neon-fuchsia shadow-[0_0_24px_-4px_rgba(168,85,247,0.7)] transition-all duration-500 group-hover:shadow-[0_0_36px_-2px_rgba(217,70,239,0.85)]">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 lg:h-5.5 lg:w-5.5 drop-shadow-[0_2px_8px_rgba(255,255,255,0.4)]">
          <path d="M8 5v14l11-7z"/>
        </svg>
        <span class="absolute inset-0 -z-10 rounded-xl bg-gradient-to-br from-brand-500 to-neon-fuchsia blur-md opacity-50 group-hover:opacity-80 transition-opacity"></span>
      </span>
      <span class="text-lg lg:text-xl tracking-wider gradient-text neon-glow">{SITE.name.toUpperCase()}</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-1 mx-2">
      {NAV.filter(n => n.href !== '/search').map((item) => {
        const active =
          item.href === '/'
            ? path === '/' || path === ''
            : path.startsWith(item.href);
        return (
          <a
            href={item.href}
            class={`relative rounded-xl px-4 py-2 text-sm font-semibold transition-all duration-300 ${
              active
                ? 'text-white'
                : 'text-gray-300 hover:text-white'
            }`}
          >
            {active && (
              <span class="absolute inset-0 -z-10 rounded-xl bg-gradient-to-br from-brand-600/40 to-neon-fuchsia/30 border border-brand-500/30 shadow-[0_0_18px_-4px_rgba(139,92,246,0.6)]"></span>
            )}
            {!active && (
              <span class="absolute inset-0 -z-10 rounded-xl bg-white/0 transition-colors hover:bg-white/[0.04]"></span>
            )}
            {item.label}
          </a>
        );
      })}
    </nav>

    <!-- Search bar (desktop only) -->
    <form action="/search" method="GET" class="hidden lg:flex relative items-center flex-1 max-w-sm" role="search">
      <span class="absolute right-3 text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
      </span>
      <input
        type="search"
        name="q"
        autocomplete="off"
        placeholder="ابحث في الأعمال…"
        class="input-neon !py-2 pr-9 text-sm"
      />
    </form>

    <!-- Right side actions -->
    <div class="flex items-center gap-1.5 shrink-0">
      <!-- Search (mobile/tablet) -->
      <a href="/search" class="lg:hidden btn-icon" aria-label="بحث">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
      </a>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-toggle"
        class="md:hidden btn-icon"
        aria-label="فتح القائمة"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6 transition-transform duration-300">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer menu -->
  <nav
    id="mobile-menu"
    class="md:hidden hidden glass-strong border-t border-white/[0.06] animate-slide-down"
  >
    <div class="container-app flex flex-col py-4 gap-1.5">
      <!-- Mobile search -->
      <form action="/search" method="GET" class="relative mb-3">
        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
          </svg>
        </span>
        <input
          type="search"
          name="q"
          placeholder="ابحث…"
          class="input-neon pr-10"
        />
      </form>
      {NAV.map((item) => {
        const active =
          item.href === '/' ? path === '/' : path.startsWith(item.href);
        return (
          <a
            href={item.href}
            class={`flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-semibold transition-all ${
              active
                ? 'text-white bg-gradient-to-l from-brand-600/30 to-neon-fuchsia/20 border border-brand-500/30 shadow-[0_0_18px_-6px_rgba(139,92,246,0.5)]'
                : 'text-gray-200 hover:bg-white/[0.04] border border-transparent'
            }`}
          >
            {navIcons[item.href] && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={`h-5 w-5 ${active ? 'text-brand-400' : 'text-gray-400'}`}>
                <path d={navIcons[item.href]}/>
              </svg>
            )}
            {item.label}
            {active && <span class="mr-auto h-2 w-2 rounded-full bg-neon-fuchsia shadow-[0_0_8px_rgba(217,70,239,0.8)]"></span>}
          </a>
        );
      })}
    </div>
  </nav>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 lg:h-[72px]"></div>

<!-- Mobile sticky bottom navigation -->
<nav class="md:hidden fixed bottom-0 left-0 right-0 z-40 glass-strong border-t border-white/[0.08]" aria-label="القائمة السفلية">
  <div class="grid grid-cols-5 h-16">
    {NAV.map((item) => {
      const active =
        item.href === '/' ? (path === '/' || path === '') : path.startsWith(item.href);
      return (
        <a
          href={item.href}
          class={`flex flex-col items-center justify-center gap-1 text-[10px] font-semibold transition-all relative ${
            active ? 'text-white' : 'text-gray-400'
          }`}
        >
          {active && (
            <span class="absolute top-0 left-1/2 -translate-x-1/2 h-0.5 w-8 rounded-b-full bg-gradient-to-l from-brand-400 to-neon-fuchsia shadow-[0_0_8px_rgba(168,85,247,0.7)]"></span>
          )}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width={active ? '2.4' : '2'} stroke-linecap="round" stroke-linejoin="round" class={`h-[22px] w-[22px] transition-transform ${active ? 'text-brand-400 scale-110' : ''}`}>
            <path d={navIcons[item.href] || ''}/>
          </svg>
          <span>{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('site-header');

  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });

  // Close mobile menu on navigation
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });

  // Header scroll effect — increase blur and add subtle border
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (header) {
      if (y > 30) {
        header.classList.add('header-scrolled');
      } else {
        header.classList.remove('header-scrolled');
      }
    }
  }, { passive: true });
</script>

<style>
  .header-bg {
    background: rgba(7, 7, 10, 0.55);
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }
  .header-scrolled .header-bg {
    background: rgba(7, 7, 10, 0.88);
    backdrop-filter: blur(28px) saturate(160%);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    border-bottom-color: rgba(167, 139, 250, 0.12);
    box-shadow: 0 8px 32px -12px rgba(0, 0, 0, 0.6);
  }
</style>
