---
const path = Astro.url.pathname;
const categories = [
  { label: 'أفلام', href: '/movies' },
  { label: 'مسلسلات', href: '/series' },
  { label: 'أنمي', href: '/anime' },
  { label: 'الأكثر مشاهدة', href: '/#most-watched' },
  { label: 'الأحدث', href: '/#latest' },
  { label: 'المفضلة', href: '/search?q=المفضلة' },
];
---

<header class="new-site-header" id="site-header" aria-label="رأس الموقع">
  <aside class="top-announcement" aria-label="إعلان الموقع">
    <div class="container-app top-announcement__inner">
      <span>مرحباً بك في سينما برو — تجربة مشاهدة عربية بتصميم جديد بالكامل</span>
      <a href="/movies">اكتشف أحدث الإضافات</a>
    </div>
  </aside>

  <div class="sticky-header-shell">
    <section class="main-header" aria-label="القائمة الرئيسية">
      <div class="container-app main-header__inner">
        <a href="/" class="brand-logo" aria-label="سينما برو الرئيسية">
          <span class="brand-logo__icon" aria-hidden="true">▶</span>
          <span class="brand-logo__text">سينما برو</span>
        </a>

        <form action="/search" method="GET" class="header-search" role="search">
          <label class="sr-only" for="global-search">بحث</label>
          <span aria-hidden="true">⌕</span>
          <input id="global-search" name="q" type="search" autocomplete="off" placeholder="ابحث عن فيلم، مسلسل، أنمي..." class="site-search-input" />
        </form>

        <nav class="header-actions" aria-label="إجراءات سريعة">
          <a class="header-icon" href="/search" aria-label="بحث">⌕</a>
          <button class="header-icon" id="menu-toggle" type="button" aria-label="فتح القائمة" aria-controls="compact-menu" aria-expanded="false">☰</button>
          <a class="header-icon" href="/search?q=جديد" aria-label="إشعارات">◔</a>
        </nav>
      </div>
    </section>

    <nav class="category-strip" aria-label="تصنيفات سريعة">
      <div class="container-app category-strip__inner">
        {categories.map((item) => {
          const normalized = item.href.split('#')[0].split('?')[0];
          const active = normalized && normalized !== '/' && path.startsWith(normalized);
          return <a href={item.href} class={`category-pill ${active ? 'is-active' : ''}`}>{item.label}</a>;
        })}
      </div>
    </nav>

    <nav id="compact-menu" class="compact-menu hidden" aria-label="القائمة المختصرة">
      <div class="container-app compact-menu__inner">
        {categories.map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('compact-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>

<style>
  .new-site-header { position: relative; z-index: 50; }
  .top-announcement { height: 40px; background: #7C3AED; color: #F9FAFB; font-size: 13px; font-weight: 700; }
  .top-announcement__inner { height: 40px; display: flex; align-items: center; justify-content: space-between; gap: 16px; white-space: nowrap; overflow: hidden; }
  .top-announcement a { color: #F9FAFB; border-bottom: 1px solid rgba(255,255,255,0.7); }
  .sticky-header-shell { position: sticky; top: 0; z-index: 50; }
  .main-header { height: 70px; background: rgba(11,15,25,0.88); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.07); }
  .main-header__inner { height: 70px; display: grid; grid-template-columns: minmax(190px, 1fr) minmax(260px, 400px) minmax(150px, 1fr); align-items: center; gap: 22px; }
  .brand-logo { display: inline-flex; align-items: center; gap: 12px; justify-self: start; }
  .brand-logo__icon { color: #2563EB; font-size: 30px; line-height: 1; filter: drop-shadow(0 0 14px rgba(37,99,235,.45)); }
  .brand-logo__text { color: #F9FAFB; font-size: 28px; font-weight: 900; letter-spacing: -0.03em; }
  .header-search { width: 400px; max-width: 100%; height: 46px; position: relative; justify-self: center; }
  .header-search span { position: absolute; right: 18px; top: 50%; transform: translateY(-50%); color: #9CA3AF; z-index: 2; font-size: 18px; }
  .header-search input { height: 46px; padding: 0 46px 0 18px; font-size: 14px; }
  .header-actions { display: flex; align-items: center; justify-content: flex-end; gap: 10px; }
  .header-icon { width: 42px; height: 42px; display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; color: #F9FAFB; background: #111827; border: 1px solid rgba(255,255,255,0.07); font-size: 19px; cursor: pointer; transition: background .2s, color .2s, transform .2s; }
  .header-icon:hover { background: #1a2235; color: #2563EB; transform: translateY(-2px); }
  .category-strip { background: #111827; border-bottom: 1px solid rgba(255,255,255,0.07); }
  .category-strip__inner { min-height: 50px; display: flex; align-items: center; gap: 10px; overflow-x: auto; scrollbar-width: none; }
  .category-strip__inner::-webkit-scrollbar { display: none; }
  .category-pill { flex: 0 0 auto; border: 1px solid rgba(255,255,255,0.07); color: #9CA3AF; border-radius: 999px; padding: 8px 16px; font-size: 13px; font-weight: 800; transition: background .2s, color .2s, border-color .2s; }
  .category-pill:hover, .category-pill.is-active { background: #2563EB; border-color: #2563EB; color: #F9FAFB; }
  .compact-menu { background: #111827; border-bottom: 1px solid rgba(255,255,255,0.07); }
  .compact-menu__inner { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 8px; padding-top: 12px; padding-bottom: 12px; }
  .compact-menu a { color: #F9FAFB; background: #0B0F19; border: 1px solid rgba(255,255,255,0.07); border-radius: 12px; padding: 12px; font-weight: 800; }
  @media (max-width: 900px) { .main-header__inner { grid-template-columns: 1fr auto; } .header-search { display: none; } .brand-logo__text { font-size: 23px; } }
  @media (max-width: 480px) { .top-announcement__inner { justify-content: center; } .top-announcement a { display: none; } .main-header__inner { gap: 12px; } .header-actions { gap: 6px; } .header-icon { width: 38px; height: 38px; } }
</style>
