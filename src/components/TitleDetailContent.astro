---
import Grid from './Grid.astro';
import RelatedAnimeSeasons from './RelatedAnimeSeasons.astro';
import SectionHeader from './SectionHeader.astro';
import SeasonsTabs from './SeasonsTabs.astro';
import TrailerEmbed from './TrailerEmbed.astro';
import type { Title, TitleIndexEntry } from '../lib/types';
import {
  buildInfoRows,
  buildMainDescription,
  cleanBrand,
  getCategoryTags,
  getWorkTitle,
} from '../lib/detailContent';
import type { DetailKind } from '../lib/detailContent';
import { getFirstEpisodeRoute } from '../lib/episodeRoutes';

interface Props {
  title: Title;
  kind: DetailKind;
  similar: TitleIndexEntry[];
  similarHref: string;
  patternId?: number;
}

const { title, kind, similar, similarHref, patternId } = Astro.props;

const workTitle = getWorkTitle(title);
const mainDescription = buildMainDescription(title, kind, patternId);
const infoRows = buildInfoRows(title, kind);
const tags = getCategoryTags(title, kind);
const categoryPath = kind === 'anime' ? 'anime' : kind === 'series' ? 'series' : 'movie';
const firstEpisode = title.seasons[0]?.episodes[0] ?? null;
const watchHref = kind === 'movie'
  ? `/watch/${title.slug}`
  : getFirstEpisodeRoute(title, categoryPath as 'series' | 'anime');
const storyTitle = kind === 'movie' ? `قصة فيلم ${workTitle}` : kind === 'series' ? `قصة مسلسل ${workTitle}` : `قصة أنمي ${workTitle}`;
const infoTitle = kind === 'movie' ? 'معلومات الفيلم' : kind === 'series' ? 'معلومات المسلسل' : 'معلومات الأنمي';
const watchTitle = kind === 'movie' ? 'صفحة مشاهدة الفيلم' : kind === 'series' ? 'صفحة مشاهدة المسلسل' : 'صفحة مشاهدة الأنمي';
const watchText = kind === 'movie'
  ? `انتقل إلى صفحة مشاهدة ${workTitle} مباشرة مع الحفاظ على صفحة التفاصيل للرجوع إلى القصة والمعلومات والتريلر.`
  : `ابدأ من الحلقة الأولى، ثم تنقل بين المواسم والحلقات من صفحة المشاهدة أو من تبويب الحلقات في هذه الصفحة.`;
const watchButton = kind === 'movie' ? 'مشاهدة الفيلم الآن' : 'مشاهدة الحلقة الأولى';
const similarTitle = kind === 'movie' ? 'أفلام مشابهة' : kind === 'series' ? 'مسلسلات مشابهة' : 'أنمي مشابه';
const similarSubtitle = kind === 'movie' ? 'اختيارات قريبة من نفس التصنيفات' : 'أعمال قريبة من نفس الأجواء والتصنيفات';
const posterAlt = `${workTitle} على CINMAPRO`;
const cinemaPlusSourcePath = title.url || `/${categoryPath}/${title.slug}`;
---

<section class="container-app py-10" data-detail-template="topcinema-inspired">
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">
    <div class="space-y-7 lg:col-span-8">
      <section class="glass-panel p-5 md:p-6">
        <h2 class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
          <span class="flex h-6 w-1 rounded-full bg-gradient-to-b from-brand-400 to-gold-400"></span>
          {storyTitle}
        </h2>
        <p class="text-sm leading-8 text-gray-300 md:text-base">{mainDescription}</p>
      </section>

      <section class="glass-panel p-5 md:p-6">
        <h2 class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
          <span class="flex h-6 w-1 rounded-full bg-gradient-to-b from-brand-400 to-gold-400"></span>
          {infoTitle}
        </h2>
        <div class="grid grid-cols-1 gap-x-6 gap-y-2 text-sm sm:grid-cols-2">
          {infoRows.map((row) => (
            <div class="flex justify-between gap-4 border-b border-white/[0.04] py-2">
              <span class="shrink-0 text-gray-400">{row.label}</span>
              <span class="text-left font-semibold text-white">{row.value}</span>
            </div>
          ))}
        </div>
      </section>

      {tags.length > 0 && (
        <section class="glass-panel p-5 md:p-6">
          <h2 class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
            <span class="flex h-6 w-1 rounded-full bg-gradient-to-b from-brand-400 to-gold-400"></span>
            التصنيفات
          </h2>
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <a
                href={`/search?q=${encodeURIComponent(tag)}`}
                class="rounded-full border border-white/[0.06] bg-white/[0.04] px-3 py-1.5 text-xs font-semibold text-gray-300 transition-colors hover:border-brand-400/40 hover:bg-brand-500/10 hover:text-brand-200"
              >
                {tag}
              </a>
            ))}
          </div>
        </section>
      )}

      <TrailerEmbed trailerId={title.trailerId} title={workTitle} type={kind} />

      {kind === 'anime' && <RelatedAnimeSeasons title={title} />}

      {firstEpisode && (
        <section class="glass-panel p-5 md:p-6">
          <h2 class="mb-3 flex items-center gap-2 text-lg font-bold text-white">
            <span class="flex h-6 w-1 rounded-full bg-gradient-to-b from-brand-400 to-gold-400"></span>
            {watchTitle}
          </h2>
          <p class="mb-5 text-sm leading-7 text-gray-300">{watchText}</p>
          <a href={watchHref} class="btn-primary w-full justify-center px-7 py-3.5 text-base sm:w-auto">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
              <path d="M8 5v14l11-7z" />
            </svg>
            {watchButton}
          </a>
        </section>
      )}

      {kind !== 'movie' && (
        <section>
          <SectionHeader
            title="المواسم والحلقات"
            subtitle={`${title.seasons_count} موسم · ${title.episodes_count} حلقة`}
            eyebrow="EPISODES"
          />
          <SeasonsTabs title={title} categoryPath={categoryPath} />
        </section>
      )}
    </div>

    <aside class="space-y-5 lg:col-span-4">
      <div class="glass-panel overflow-hidden lg:sticky lg:top-24">
        <div class="relative aspect-[2/3] w-full bg-surface-3">
          {title.poster ? (
            <img
              src={title.poster}
              alt={posterAlt}
              loading="lazy"
              decoding="async"
              referrerpolicy="no-referrer"
              class="h-full w-full object-cover"
            />
          ) : (
            <div class="flex h-full w-full items-center justify-center p-6 text-center text-sm text-gray-400">{workTitle}</div>
          )}
          <div class="absolute inset-0 bg-gradient-to-t from-surface-0 via-transparent to-transparent"></div>
          <div class="absolute bottom-0 right-0 left-0 p-4">
            <div class="mb-3 flex flex-wrap gap-2">
              <span class="badge-hd">{title.quality || 'HD'}</span>
              {title.year && <span class="chip-surface">{title.year}</span>}
            </div>
            {firstEpisode && (
              <a href={watchHref} class="btn-primary w-full justify-center px-5 py-3 text-sm">
                مشاهدة العمل
              </a>
            )}
          </div>
        </div>
        <div class="space-y-2 p-5 text-sm">
          <div class="flex justify-between gap-4 border-b border-white/[0.04] py-2">
            <span class="text-gray-400">النوع</span>
            <span class="font-semibold text-white">{title.category_label}</span>
          </div>
          <div class="flex justify-between gap-4 border-b border-white/[0.04] py-2">
            <span class="text-gray-400">الجودة</span>
            <span class="font-semibold text-white">{title.quality || 'HD'}</span>
          </div>
          <div class="flex justify-between gap-4 py-2">
            <span class="text-gray-400">اللغة</span>
            <span class="font-semibold text-white">{cleanBrand(title.language) || 'مترجم'}</span>
          </div>
        </div>
      </div>
    </aside>
  </div>

  {similar.length > 0 && (
    <div class="mt-14 md:mt-20">
      <SectionHeader title={similarTitle} subtitle={similarSubtitle} eyebrow="RELATED" href={similarHref} />
      <Grid items={similar} />
    </div>
  )}
</section>

<div
  id="cinema-plus-popup"
  class="cinema-plus-popup"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="cinema-plus-popup-title"
  data-source-path={cinemaPlusSourcePath}
  dir="rtl"
>
  <article class="cinema-plus-popup__card" aria-describedby="cinema-plus-popup-description">
    <header class="cinema-plus-popup__header">
      <h2 id="cinema-plus-popup-title">شاهد على سينما بلس</h2>
      <button class="cinema-plus-popup__close" type="button" aria-label="إغلاق النافذة" data-cinema-plus-close>
        ×
      </button>
    </header>

    <div class="cinema-plus-popup__body">
      <h3 class="cinema-plus-popup__movie-name">{workTitle}</h3>
      <p id="cinema-plus-popup-description" class="cinema-plus-popup__subtitle">
        متاح بجودة 1080p مترجم للعربية
      </p>
      <a class="cinema-plus-popup__primary" href="https://cinemanaplus.site" target="_blank" rel="noopener noreferrer" data-cinema-plus-link>
        مشاهدة على سينما بلس
      </a>
      <button class="cinema-plus-popup__secondary" type="button" data-cinema-plus-close>
        تخطي — الاستمرار في هذا الموقع
      </button>
    </div>
  </article>
</div>

<script is:inline>
  (() => {
    const popup = document.getElementById('cinema-plus-popup');
    if (!popup) return;

    const link = popup.querySelector('[data-cinema-plus-link]');
    const closeButtons = popup.querySelectorAll('[data-cinema-plus-close]');
    const sourcePath = popup.getAttribute('data-source-path') || window.location.pathname;
    const pathMap = {
      movie: 'f',
      series: 'd',
      anime: 'n',
    };

    const buildCinemaPlusUrl = () => {
      const currentUrl = new URL(window.location.href);
      const url = new URL(sourcePath, currentUrl.origin);
      const segments = url.pathname.split('/').filter(Boolean);
      const firstSegment = segments[0];

      if (firstSegment && Object.prototype.hasOwnProperty.call(pathMap, firstSegment)) {
        segments[0] = pathMap[firstSegment];
      }

      url.protocol = 'https:';
      url.hostname = 'cinemanaplus.site';
      url.port = '';
      url.pathname = `/${segments.join('/')}`;
      url.search = '';
      url.hash = '';

      return url.toString();
    };

    if (link instanceof HTMLAnchorElement) {
      link.href = buildCinemaPlusUrl();
    }

    const showPopup = () => {
      popup.classList.add('is-visible');
      popup.setAttribute('aria-hidden', 'false');
    };

    const closePopup = () => {
      popup.classList.remove('is-visible');
      popup.setAttribute('aria-hidden', 'true');
    };

    const popupTimer = window.setTimeout(showPopup, 3000);

    closeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        window.clearTimeout(popupTimer);
        closePopup();
      });
    });

    popup.addEventListener('click', (event) => {
      if (event.target === popup) {
        window.clearTimeout(popupTimer);
        closePopup();
      }
    });
  })();
</script>
